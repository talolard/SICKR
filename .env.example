# Copy this file to .env and fill values locally.

# GCP / Gemini
GCP_PROJECT_ID=gen-lang-client-0545732168
GCP_REGION=us-central1
GEMINI_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=vertex_gemini
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GEMINI_API_KEY=

# Local data paths
IKEA_RAW_CSV_PATH=data/IKEA_product_catalog.csv
DUCKDB_PATH=data/ikea.duckdb

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# App defaults
APP_ENV=dev
DEFAULT_QUERY_LIMIT=25
DEFAULT_MARKET=Germany
EMBEDDING_PARALLELISM=8
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSIONS=256
EMBEDDING_REQUESTS_PER_MINUTE=90
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BASE_SECONDS=2.0
EMBEDDING_RETRY_MAX_SECONDS=90.0
EMBEDDING_RETRY_JITTER_SECONDS=1.0
EMBEDDING_UPSERT_CHUNK_SIZE=25
EVAL_GENERATION_BATCH_SIZE=25
EVAL_GENERATION_PARALLELISM=4
EVAL_GENERATION_MAX_ROUNDS=8
VSS_BUILD_INDEX=false
VSS_METRIC=cosine
RETRIEVAL_LOW_CONFIDENCE_THRESHOLD=0.15
