# Copy this file to .env and fill values locally.

# Google / Gemini
GCP_PROJECT_ID=gen-lang-client-0545732168
GCP_REGION=us-central1
GEMINI_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=

# fal.ai
FAI_AI_API_KEY=

# PydanticAI embedding provider
EMBEDDING_PROVIDER=pydantic_ai_google
EMBEDDING_MODEL_URI=google-gla:gemini-embedding-001
EMBEDDING_DIMENSIONS=256

# Local stores
DUCKDB_PATH=data/ikea.duckdb
MILVUS_LITE_URI=data/milvus_lite.db
MILVUS_COLLECTION=ikea_product_embeddings

# Runtime behavior
APP_ENV=dev
DEFAULT_QUERY_LIMIT=25
FEEDBACK_CAPTURE_ENABLED=false
FEEDBACK_ROOT_DIR=comments
TRACE_CAPTURE_ENABLED=false
TRACE_ROOT_DIR=traces
RETRIEVAL_CANDIDATE_LIMIT=250
EMBEDDING_QUERY_BATCH_SIZE=16
RERANK_ENABLED=true
RERANK_BACKEND=transformer
RERANK_CANDIDATE_LIMIT=100
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
LOGFIRE_TOKEN=
LOGFIRE_SEND_MODE=if-token-present
LOGFIRE_SERVICE_NAME=ikea-agent

# UI feature flags
NEXT_PUBLIC_TRACE_CAPTURE_ENABLED=0
