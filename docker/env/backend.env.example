# Backend runtime environment example for the deployed host.
# Secrets are injected separately from AWS Secrets Manager.

APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=true
LOGFIRE_SERVICE_NAME=ikea-agent
LOGFIRE_ENVIRONMENT=dev
LOGFIRE_SERVICE_VERSION=0.1.0
LOGFIRE_SEND_MODE=if-token-present

ALLOW_MODEL_REQUESTS=1
IMAGE_SERVING_STRATEGY=direct_public_url
IMAGE_SERVICE_BASE_URL=https://designagent.talperry.com/static/product-images

ARTIFACT_ROOT_DIR=/var/lib/ikea-agent/artifacts
FEEDBACK_CAPTURE_ENABLED=0
TRACE_CAPTURE_ENABLED=0

# Deploy-only bootstrap inputs; not required for steady-state runtime.
IKEA_IMAGE_CATALOG_ROOT_DIR=/var/lib/ikea-agent/bootstrap/ikea_image_catalog
IKEA_IMAGE_CATALOG_RUN_ID=

