# Host deploy environment example.
# Image refs come from the release manifest.
# Secret ARNs come from Terraform outputs.

AWS_REGION=eu-central-1
COMPOSE_PROJECT_NAME=ikea-agent-dev
PRODUCT_IMAGE_BASE_URL=https://designagent.talperry.com/static/product-images
BACKEND_HOST_PORT=8000
UI_HOST_PORT=3000
DEPLOY_STATE_DIR=/var/lib/ikea-agent/deploy
BACKEND_SECRETS_ENV_FILE=/var/lib/ikea-agent/deploy/runtime/backend.secrets.env
HOST_ARTIFACT_ROOT_DIR=/var/lib/ikea-agent/artifacts

BACKEND_IMAGE_REF=
UI_IMAGE_REF=
RELEASE_VERSION=
RELEASE_GIT_TAG=
RELEASE_GIT_SHA=

BACKEND_APP_SECRET_ARN=
MODEL_PROVIDER_SECRET_ARN=
OBSERVABILITY_SECRET_ARN=
DATABASE_SECRET_ARN=
