aws_account_id = "046673074482"
environment    = "dev"
region         = "eu-central-1"

hosted_zone_name  = "talperry.com"
public_hostname   = "designagent.talperry.com"
origin_hostname   = "origin.designagent.talperry.com"
github_repository = "talolard/SICKR"
release_branch    = "release"

vpc_cidr              = "10.42.0.0/16"
public_subnet_cidrs   = ["10.42.0.0/24", "10.42.1.0/24"]
database_subnet_cidrs = ["10.42.10.0/24", "10.42.11.0/24"]

app_host_instance_type          = "t3.small"
app_host_root_volume_size_gib   = 20
app_ui_origin_port              = 3000
app_backend_origin_port         = 8000
app_host_artifact_root_dir      = "/var/lib/ikea-agent/artifacts"
app_host_ami_ssm_parameter_name = "/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64"

database_name                    = "ikea_agent"
database_master_username         = "ikea_agent_admin"
database_engine_version          = "17.7"
database_min_capacity            = 0
database_max_capacity            = 2
database_seconds_until_auto_pause = 900

cloudfront_price_class                         = "PriceClass_100"
cloudfront_default_origin_read_timeout_seconds = 30
cloudfront_ag_ui_origin_read_timeout_seconds   = 120
cloudfront_origin_keepalive_timeout_seconds    = 60
